includes:
    - vendor/larastan/larastan/extension.neon
    - vendor/nesbot/carbon/extension.neon

parameters:
    paths:
        - app/
        - bootstrap/app.php
        - config/
        - database/
        - routes/

    level: 5

    ignoreErrors:
        -
            message: '#Call to an undefined method[\s\S]*::allowedFilters\(\)\.#'
            identifier: method.notFound
            path: app/
